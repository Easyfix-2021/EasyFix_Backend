# ────────────────────────────────────────────────────────────────
# EasyFix_Backend — Environment Template
# Copy to .env and fill in values. .env is gitignored.
# ────────────────────────────────────────────────────────────────

# Server
PORT=5100
NODE_ENV=development
LOG_LEVEL=debug

# Database (shared with legacy services — DO NOT alter schema)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=easyfix_core
DB_USER=
DB_PASSWORD=
DB_CONNECTION_LIMIT=20
DB_CONNECT_TIMEOUT=30000

# CORS — allowed frontend origins (comma-separated)
CRM_URL=http://localhost:5180
CLIENT_URL=http://localhost:5181

# JWT (used in Step 2)
JWT_SECRET=
JWT_EXPIRY=30d

# File uploads (used in Step 10)
UPLOAD_ROOT_PATH=/var/www/html/easydoc
UPLOAD_EASYFIXER_DOCS=/var/www/html/easydoc/easyfixer_documents
UPLOAD_JOB_FILES=/var/www/html/easydoc/upload_jobs
UPLOAD_INVOICES=/var/www/html/easydoc/client_invoice
FILE_BASE_URL=/easydoc

# Test-mode recipient overrides (dev/QA only — leave blank in production).
# When set, every outbound message is redirected to these values regardless of
# the real recipient. Applied at the last point inside each notification
# service, so no call path can bypass them.
TEST_EMAILS=
TEST_MOBILE=
TEST_FCM_TOKEN=
NOTIFICATIONS_DISABLE=false

# QA / dev convenience — set to "true" to use deterministic OTPs for login:
#   Email login → OTP = 2468 (any address)
#   Mobile login → OTP = last 4 digits of dialed number
# Lets you log in without an SMS/email gateway. NEVER set on production —
# it would be a complete auth bypass. See utils/otp.js::resolveLoginOtp().
QA_DETERMINISTIC_OTP=true

# Auto-assignment (used in Step 9)
MAX_TRAVEL_DISTANCE_KM=15
MAX_CONCURRENT_JOBS=5
WEIGHT_DISTANCE=0.35
WEIGHT_WORKLOAD=0.30
WEIGHT_RATING=0.20
WEIGHT_COMPLETION=0.15

# Notifications (used in Step 11)
# ─── Email: Microsoft Graph API (active 2026-04-20+) ──────────────────────
# App registration needs Mail.Send (application permission), admin-consented.
# Sender mailbox must be licensed in the tenant.
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_SENDER_EMAIL=ithelpdesk@easyfix.in
# ─── Email: Gmail SMTP (ARCHIVED — un-comment if reverting) ───────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
SMS_API_URL=http://smscountry.com/SMSCwebservice_Bulk.aspx
SMS_USERNAME=
SMS_PASSWORD=
SMS_SENDER_ID=EsyFix
GALLABOX_URL=https://server.gallabox.com/devapi/messages/whatsapp
GALLABOX_API_KEY=
GALLABOX_API_SECRET=
GALLABOX_CHANNEL_ID=
KALEYRA_BASE_URL=https://api-voice.kaleyra.com/v1
KALEYRA_API_KEY=
FCM_API_KEY=

# Webhook (used when /api/webhook/* is built)
WEBHOOK_API_KEY=

# ─── QuickSight session bridge (header button on Home + Manage Jobs) ─────
# Mints an HS256 JWT { session_proof, user_id, exp, iat } that the
# EF-QuickSight Angular app's API server verifies with the SAME secret
# on its side. The secret must match between this backend and the
# QuickSight backend; otherwise tokens are rejected with "invalid
# signature". Source the value from the legacy CRM deploy or your ops
# vault — do NOT invent one here unless you also rotate it on the
# QuickSight side at the same time.
#
# Empty value is safe — the /admin/quicksight/token endpoint returns
# 503 "QuickSight is not configured" and the frontend shows a
# coming-soon page instead of dead-ending the button.
#
# CONFIRMED 2026-05-13 by reading legacy ACD_APIs source: the JWT
# verifier secret is hardcoded as the literal string "esyfixsecret"
# in JwtUtil.java line 30. Same value is used by the SPOC Angular
# dashboard's QuickSight surface. If the standalone EF-QuickSight
# app uses the same engineering team's verifier (highly likely),
# this same value works there too. Try this first; if "Access
# Denied" persists, the issue is whitelisting on the QuickSight
# side, not the signature.
QUICKSIGHT_JWT_SECRET=esyfixsecret
# Base URLs returned alongside the token for ops scripts. The frontend
# already has the NEXT_PUBLIC_*_QUICKSIGHT_URL pair, so these are
# optional — set them only if you want server-side callers to use the
# returned `fullUrl` directly.
QUICKSIGHT_QA_URL=https://uat.easyfix.in
QUICKSIGHT_PROD_URL=https://corporates.core.easyfix.in
