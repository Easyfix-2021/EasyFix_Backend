# ============================================================================
# bootstrap-env.example — REFERENCE LIST of every env var the EasyFix
# stack expects on the EC2.
#
# This file is NOT consumed by any script — it's documentation. To add /
# update a value, run the interactive script:
#
#     sudo bash /opt/easyfix/repos/EasyFix_Backend/deploy/bootstrap-env.sh
#
# The script prompts for one key at a time, asks which file it belongs
# in, takes the value (masked for secrets), then auto-restarts the
# affected container.
#
# Use this file as a checklist: for a fresh EC2, run the script once
# per key listed below.
# ============================================================================


# ────────────────────────────────────────────────────────────────────
# /opt/easyfix/.env  (chmod 644, no real secrets, compose interpolation)
# ────────────────────────────────────────────────────────────────────
# These two values are AUTO-MANAGED by the GitHub Actions deploy
# workflows. Don't set them manually — each push to `QA` updates the
# corresponding line. They're listed here so you know what to expect
# when inspecting /opt/easyfix/.env on a running box.
BACKEND_IMAGE=902810393464.dkr.ecr.ap-south-1.amazonaws.com/easyfix/backend:qa-<sha>
CRM_UI_IMAGE=902810393464.dkr.ecr.ap-south-1.amazonaws.com/easyfix/crm-ui:qa-<sha>

# NEXT_PUBLIC_API_URL is no longer in this file. It's now a GitHub
# secret (QA_API_URL) that the CRM-UI workflow passes to docker build
# as a --build-arg. The value gets BAKED into the static JS chunks at
# build time. To change it: update QA_API_URL in GitHub → re-run the
# CRM-UI workflow.


# ────────────────────────────────────────────────────────────────────
# /opt/easyfix/backend.env  (chmod 600, real secrets, runtime mount)
# ────────────────────────────────────────────────────────────────────

# Express runtime
NODE_ENV=production
PORT=5100

# Database — shared QA easyfix_core
DB_HOST=111.93.206.91
DB_PORT=3306
DB_USER=easyfix_qa
DB_PASSWORD=<secret>
DB_NAME=easyfix_core

# JWT — generate fresh, do NOT reuse the legacy "esyfixsecret"
#   openssl rand -hex 32
JWT_SECRET=<secret>
JWT_EXPIRY=30d

# 1Office Suite SSO
SUITE_URL=https://suite.1office.in

# Microsoft Graph (transactional email)
MS_GRAPH_TENANT_ID=<secret>
MS_GRAPH_CLIENT_ID=<secret>
MS_GRAPH_CLIENT_SECRET=<secret>
MS_GRAPH_SENDER_EMAIL=ithelpdesk@easyfix.in

# Provider feature flags — keep TRUE for QA until deliberate cutover
NOTIFICATIONS_DISABLE=true
WEBHOOKS_DISABLE=true
TEST_EMAILS=harshit@channelplay.in
